# Copy to ~/.gitconfig.local and fill in. Never commit ~/.gitconfig.local.
#
# .gitconfig includes ~/.gitconfig.local last, so anything set here overrides
# the tracked config. Git ignores the include silently when the file is absent.
#
# Use a different identity (optionally unsigned) for repos under some directory:
#
# [includeIf "gitdir:~/path/to/those/repos/"]
#     path = ~/.gitconfig.work
#
# ...where ~/.gitconfig.work holds:
# [user]
#     email = you@example.org
#     signingkey = 0xYOURKEYID
# [commit]
#     gpgsign = false
# [tag]
#     gpgsign = false
