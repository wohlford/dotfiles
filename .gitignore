# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Editor backups
*~
*.swp
*.swo

# GnuPG runtime
pubring.gpg
pubring.gpg~
secring.gpg
trustdb.gpg
tofu.db
random_seed
S.gpg-agent*
S.scdaemon
*.status
.gpg-v21-migrated
crls.d/
private-keys-v1.d/
openpgp-revocs.d/

# Secrets — never commit these
.env
*.pem
*.key
id_rsa
id_ed25519
.gitconfig.local
.bash_aliases.local

# Machine-local SSH host configs — private hosts must never land in this
# public repo; only the tracked hosts.conf template is allowed
.ssh/config.d/*.conf
!.ssh/config.d/hosts.conf

# Vim persistent-undo data — the live undo dir is symlinked into this tree
# by install.sh, and undo files can contain anything ever typed in a buffer
.vim/undo/*
!.vim/undo/.gitkeep
