Include config.d/*.conf

# Global
Host *
  PubkeyAuthentication yes

  # Crypto: modern OpenSSH defaults (incl. post-quantum KEX) apply and improve
  # with upgrades; only legacy SHA-1/MD5 algorithms are subtracted. An older box
  # that needs them gets a per-host exception in config.d (first-match-wins) —
  # see config.d/hosts.conf for the pattern
  HostKeyAlgorithms -ssh-rsa,ssh-rsa-cert-v01@openssh.com
  KexAlgorithms -*-sha1
  MACs -*md5*,*sha1*,umac-64*
  Compression no
  HashKnownHosts no
  VerifyHostKeyDNS yes
  ControlMaster auto
  ControlPath ~/.ssh/masters/%r@%h:%p
  ControlPersist 4h
  ServerAliveInterval 60
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_ed25519
  IdentityFile ~/.ssh/id_rsa
  SendEnv LANG LC_*
